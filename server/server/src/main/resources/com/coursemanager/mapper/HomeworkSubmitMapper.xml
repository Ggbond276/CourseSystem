<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.coursemanager.mapper.HomeworkSubmitMapper">

    <resultMap id="basemap" type="com.coursemanager.pojo.HomeworkSubmit">
        <id column="id" property="id" />
        <result column="homework_id" property="homeworkId" />
        <result column="student_id" property="studentId" />
        <result column="status" property="status" />
        <result column="content" property="content" />
        <result column="attachments" property="attachments" />
        <result column="submit_time" property="submitTime" />
        <result column="score" property="score" />
        <result column="teacher_comment" property="teacherComment" />
        <result column="similarity" property="similarity" />
        <result column="word_count" property="wordCount" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 条件查询作业提交记录 -->
    <select id="selectCondition" resultMap="basemap" parameterType="com.coursemanager.lang.HomeworkSubmitCondition">
        SELECT * FROM homework_submit
        <where>
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="homeworkId != null">
                AND homework_id = #{homeworkId}
            </if>
            <if test="studentId != null">
                AND student_id = #{studentId}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="startTime != null">
                AND submit_time &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND submit_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY submit_time DESC
    </select>

    <!-- 根据课程ID查出所有学生用户ID（role=2） -->
    <select id="selectStudentIdListByCourseId" resultType="java.lang.Long">
        SELECT user_id
        FROM user_course
        WHERE course_id = #{courseId}
          AND role = 2
        ORDER BY join_time ASC
    </select>

    <!-- 教师批阅大厅：联表 user 拿到学生姓名、学号，支持 status / studentName 筛选 -->
    <!-- 字段对齐 B1_API.md 接口 3 的 data[] 每一项 -->
    <select id="selectSubmitListForTeacher" resultType="java.util.LinkedHashMap">
        SELECT
            hs.id                                AS submitId,
            u.name                               AS studentName,
            u.account                            AS studentAccount,
            hs.status                            AS status,
            hs.submit_time                       AS submitTime,
            hs.similarity                        AS similarity,
            hs.word_count                        AS wordCount,
            hs.score                             AS score
        FROM homework_submit hs
        -- INNER JOIN：只显示已经有提交记录的学生行
        -- 老师批阅大厅关注的是"谁交了/谁没交"，但未交的占位记录没有 user 关联意义，
        -- 此处先实现"已存在的提交记录"列表，未交学生通过接口 2 的 unsubmittedCount 统计即可
        INNER JOIN user u ON u.id = hs.student_id
        <where>
            hs.homework_id = #{homeworkId}
            <if test="status != null">
                AND hs.status = #{status}
            </if>
            <if test="studentName != null and studentName != ''">
                AND u.name LIKE CONCAT('%', #{studentName}, '%')
            </if>
        </where>
        -- 排序：先按状态升序（让"未批阅"的靠前，方便老师批），再按提交时间倒序
        ORDER BY hs.status ASC, hs.submit_time DESC
    </select>

</mapper>
