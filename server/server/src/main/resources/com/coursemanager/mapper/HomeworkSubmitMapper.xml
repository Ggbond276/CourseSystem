<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.coursemanager.mapper.HomeworkSubmitMapper">

    <resultMap id="basemap" type="com.coursemanager.pojo.HomeworkSubmit">
        <id column="id" property="id" />
        <result column="homework_id" property="homeworkId" />
        <result column="student_id" property="studentId" />
        <result column="status" property="status" />
        <result column="content" property="content" />
        <result column="attachments" property="attachments" />
        <result column="submit_time" property="submitTime" />
        <result column="score" property="score" />
        <result column="teacher_comment" property="teacherComment" />
        <result column="similarity" property="similarity" />
        <result column="word_count" property="wordCount" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 教师批阅大厅专用 ResultMap：明确映射每个列，避免 MyBatis 对 status 列的自动类型推断异常 -->
    <resultMap id="teacherSubmitMap" type="java.util.LinkedHashMap">
        <id column="submitId" property="submitId" />
        <result column="studentName" property="studentName" />
        <result column="studentAccount" property="studentAccount" />
        <result column="submitStatus" property="status" />
        <result column="submitTime" property="submitTime" />
        <result column="similarity" property="similarity" />
        <result column="wordCount" property="wordCount" />
        <result column="score" property="score" />
    </resultMap>

    <!-- 条件查询作业提交记录 -->
    <select id="selectCondition" resultMap="basemap" parameterType="com.coursemanager.lang.HomeworkSubmitCondition">
        SELECT * FROM homework_submit
        <where>
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="homeworkId != null">
                AND homework_id = #{homeworkId}
            </if>
            <if test="studentId != null">
                AND student_id = #{studentId}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="startTime != null">
                AND submit_time &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND submit_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY submit_time DESC
    </select>

    <!-- 根据课程ID查出所有学生用户ID（role=2） -->
    <select id="selectStudentIdListByCourseId" resultType="java.lang.Long">
        SELECT user_id
        FROM user_course
        WHERE course_id = #{courseId}
          AND role = 2
        ORDER BY join_time ASC
    </select>

    <!-- 教师批阅大厅：联表 user 拿到学生姓名、学号，支持 status / studentName 筛选 -->
    <!-- 字段对齐 B1_API.md 接口 3 的 data[] 每一项 -->
    <select id="selectSubmitListForTeacher"
            resultType="com.coursemanager.pojo.HomeworkSubmit">
        SELECT hs.id, hs.homework_id, hs.student_id, hs.status,
               hs.submit_time, hs.score, hs.similarity, hs.word_count
        FROM homework_submit hs
        <where>
            hs.homework_id = #{homeworkId}
            <if test="filterStatus != null">
                AND hs.status = #{filterStatus}
            </if>
        </where>
        ORDER BY hs.status ASC, hs.submit_time DESC
    </select>

    <!--
        学生端：根据 homeworkId + studentId 精准定位一条提交记录
        B2 用法：学生作业详情 / 列表 关联 mySubmission / status / score
    -->
    <select id="selectByHomeworkIdAndStudentId" resultMap="basemap">
        SELECT <include refid="baseColumnList" />
        FROM homework_submit
        WHERE homework_id = #{homeworkId}
          AND student_id  = #{studentId}
        LIMIT 1
    </select>

    <!--
        学生端：根据 作业ID 列表 + studentId 批量取该学生在所有作业下的提交记录
        B2 用法：学生作业列表，一次 JOIN 取完所有 status/score，避免 N+1
        关键：返回的行数 ≤ 作业数（没提交的作业不会出现），前端按 homeworkId 自己回填默认 status=0
    -->
    <select id="selectByHomeworkIdListAndStudentId" resultMap="basemap">
        SELECT <include refid="baseColumnList" />
        FROM homework_submit
        WHERE student_id = #{studentId}
          AND homework_id IN
          <foreach collection="homeworkIdList" item="homeworkId" open="(" close=")" separator=",">
              #{homeworkId}
          </foreach>
    </select>

    <!--
        共用列清单：让 selectByHomeworkIdAndStudentId / selectByHomeworkIdListAndStudentId
        共用同一份列名拼接，避免 SQL 重复
    -->
    <sql id="baseColumnList">
        id, homework_id, student_id, status, content, attachments,
        submit_time, score, teacher_comment, similarity, word_count,
        create_time, update_time
    </sql>

    <!--
        学生工作台统计：累加所有 status=2（已批改）的作业分数
        COALESCE 兜底，没有已批改记录时返回 0 而非 NULL
    -->
    <select id="sumScoredScoreByStudentId" resultType="java.lang.Integer">
        SELECT COALESCE(SUM(score), 0)
        FROM homework_submit
        WHERE student_id = #{studentId}
          AND status = 2
          AND score IS NOT NULL
    </select>

</mapper>
